# ── WanderSuite BETA Environment ─────────────────────────────────────────────
# Beta runs on separate ports so main and beta can run in parallel on Unraid.
#
# Build + start:
#   BUILD_DATE="$(date '+%Y-%m-%d %H:%M')" docker compose up -d --build

# Frontend port (Nginx) — beta default: 8767
HOST_PORT=8767

# Backend port (FastAPI) — beta default: 8768
BACKEND_PORT=8768

# Timezone for scheduler (cron)
TZ=Europe/Rome

# Host path for SQLite database — separate from main!
DATA_DIR=/mnt/user/appdata/wandersuite-beta/data

# AES-Fernet key — can be same as main or separate
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET=change-me-before-first-start

# ── Authentication (optional) ──────────────────────────────────────────────────
AUTH_ENABLED=false
JWT_SECRET=change-me-to-a-real-secret

# ── Beta build date (set automatically by docker compose up --build) ──────────
# Do NOT set manually — set via: BUILD_DATE="$(date '+%Y-%m-%d %H:%M')" docker compose up -d --build
# BUILD_DATE=

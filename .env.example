# WanderSuite — Umgebungsvariablen
# Kopiere diese Datei zu .env und passe die Werte an

# Frontend Port (default: 8765)
PORT=8765

# Backend Port — direkt erreichbar für API-Calls (default: 8766)
BACKEND_PORT=8766

# Encryption Key für API Keys (bitte ändern!)
APP_SECRET=wandersuite-change-me-please

# SQLite Datenbank-Pfad (innerhalb des Containers)
DB_PATH=/data/tracker.db

# ── WanderSuite BETA Environment ─────────────────────────────────────────────
# Build + start:
#   BUILD_DATE="$(date '+%Y-%m-%d %H:%M')" docker compose up -d --build

HOST_PORT=8767
BACKEND_PORT=8768
TZ=Europe/Rome
DATA_DIR=/mnt/user/appdata/wandersuite-beta/data

# Fernet key -- generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET=change-me-before-first-start

# ── Authentication ─────────────────────────────────────────────────────────────
AUTH_ENABLED=false
JWT_SECRET=change-me-to-a-real-secret

# ── WebAuthn / Passkeys ────────────────────────────────────────────────────────
# RP_ID: your domain WITHOUT protocol or port
#   Local testing: localhost
#   Production:    wandersuite.deinedomain.de
WEBAUTHN_RP_ID=localhost

# RP_NAME: displayed in the browser's passkey dialog
WEBAUTHN_RP_NAME=WanderSuite

# ORIGIN: exact URL the browser uses to access the frontend
#   Local:      http://localhost:8767
#   Production: https://wandersuite.deinedomain.de
WEBAUTHN_ORIGIN=http://localhost:8767

# ── Notifications ─────────────────────────────────────────────────────────────
# User notification credentials are stored ENCRYPTED per user in the database.
# They are configured via Settings -> Mein Bereich -> Benachrichtigungen in the UI.
# These .env variables are for DOCUMENTATION ONLY -- do NOT put real secrets here.
#
# Telegram:
#   Bot Token: obtain from @BotFather on Telegram
#   Chat ID:   obtain from @userinfobot on Telegram
# TELEGRAM_BOT_TOKEN=<your-bot-token>
# TELEGRAM_CHAT_ID=<your-chat-id>
#
# Gotify:
#   Server URL: your self-hosted Gotify instance (e.g. https://gotify.example.com)
#   App Token:  create an application in Gotify and copy its token
# GOTIFY_URL=<https://gotify.your-domain.de>
# GOTIFY_APP_TOKEN=<app-token-from-gotify>

# ── Beta build date ────────────────────────────────────────────────────────────
# Set via: BUILD_DATE="$(date '+%Y-%m-%d %H:%M')" docker compose up -d --build
# BUILD_DATE=

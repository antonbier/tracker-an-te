# WanderSuite — Konfiguration
# Kopiere diese Datei: cp .env.example .env
# Passe die Werte an deinen Server an, dann: docker compose up -d --build

# ── Ports ─────────────────────────────────────────────────────────────────────
# Frontend (Nginx) — im Browser aufrufen: http://DEINE-IP:${HOST_PORT}
HOST_PORT=8765

# Backend (FastAPI) — direkt vom Browser für API-Calls erreichbar
BACKEND_PORT=8766

# ── Zeitzone ──────────────────────────────────────────────────────────────────
# Bestimmt wann der tägliche Scraping-Cronjob läuft (Standard: 07:00 Uhr)
# Komplette Liste: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Rome

# ── Datenspeicher ─────────────────────────────────────────────────────────────
# Pfad auf dem HOST für SQLite-Datenbank und persistente Daten.
# Wird in den Container als /app/data gemountet.
# Tipp für Unraid: /mnt/user/appdata/wandersuite/data
DATA_DIR=./data

# ── Sicherheit ────────────────────────────────────────────────────────────────
# Encryption Key für alle gespeicherten API Keys (AES-Fernet).
# WICHTIG: Vor dem ersten Start ändern! Beliebiger String ≥ 16 Zeichen.
# Nach dem ersten Start NICHT mehr ändern — sonst sind gespeicherte Keys unlesbar.
APP_SECRET=wandersuite-change-me-please-min-16-chars

# ════════════════════════════════════════════════════════════
#  WanderSuite — Environment Variables
#  Kopiere diese Datei nach .env und passe die Werte an.
# ════════════════════════════════════════════════════════════

# ── Ports ───────────────────────────────────────────────────
# Frontend (Nginx + Svelte)
HOST_PORT=8765

# Backend (FastAPI — nur für direkten Zugriff / Debugging)
BACKEND_PORT=8766

# ── Timezone ────────────────────────────────────────────────
# Wird für den APScheduler (täglicher Scrape um 07:00) genutzt.
# Siehe: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Rome

# ── Datenpfade ───────────────────────────────────────────────
# Unraid: Pfad auf dem Host, wo SQLite-DB gespeichert wird.
# Standard Unraid-Konvention: /mnt/user/appdata/<app-name>/data
DATA_DIR=/mnt/user/appdata/wandersuite/data

# ── App Secret ───────────────────────────────────────────────
# AES-Fernet Schlüssel für verschlüsselte Settings in der DB.
# ⚠️  VOR dem ersten Start setzen und NIEMALS danach ändern!
# Generieren: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET=CHANGE_ME_BEFORE_FIRST_START

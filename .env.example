# ── WanderSuite Environment ──────────────────────────────────────────────────

# Frontend port (Nginx)
HOST_PORT=8765

# Backend port (FastAPI — direct access for Swagger etc.)
BACKEND_PORT=8766

# Timezone for scheduler (cron)
TZ=Europe/Rome

# Host path for SQLite database and persistent data
DATA_DIR=./data

# AES-Fernet key for encrypting API keys in DB.
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️  Set ONCE before first start. Never change after — DB becomes unreadable.
APP_SECRET=change-me-before-first-start

# ── Authentication (optional) ─────────────────────────────────────────────────
# Set AUTH_ENABLED=true to require login (recommended for public/external access)
# Leave false for local/home network use — no login required.
AUTH_ENABLED=false

# JWT signing secret — required when AUTH_ENABLED=true
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-real-secret
